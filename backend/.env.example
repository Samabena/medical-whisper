# Voice-to-Form — exemple de configuration (CORE-0.2). Copier en `.env`.
# Les secrets n'ont PAS de défaut : leur absence casse au démarrage (volontaire).

# --- Secrets obligatoires ---------------------------------------------------
JWT_SECRET=change-me-32-caracteres-minimum-0123456789
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=change-me           # OU ADMIN_PASSWORD_HASH (argon2) en prod

# --- Persistance ------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://vtf:vtf@db:5432/voicetoform
REDIS_URL=redis://redis:6379/0

# --- Agent vocal (architecture v3 = sandwich) -------------------------------
# stub (dev) | sandwich (v3 : STT+agent+TTS) | llm (texte seul)
SPEECH_AGENT=stub

# --- STT (sandwich) ---------------------------------------------------------
STT_BACKEND=stub                   # stub (dev) | whisperlive (serveur en ligne de l'équipe)
WHISPERLIVE_URL=ws://srv-team-ia:9300
WHISPER_MODEL=small                # large-v3 en prod
# STT_LANGUAGE=                    # vide ⇒ langue du compte/formulaire

# --- TTS (sandwich) ---------------------------------------------------------
TTS_BACKEND=stub                   # stub (dev) | piper_http (conteneur dédié) | piper (binaire local)
PIPER_URL=http://piper:5000        # serveur Piper HTTP (backend piper_http)
TTS_VOICE_PATH=                    # chemin .onnx de la voix Piper (backend piper local)
PIPER_BINARY=piper

# --- Agent conversationnel & extraction (LLM, Ollama Cloud) -----------------
AGENT_BACKEND=scripted             # scripted (dev) | ollama (streaming)
EXTRACTOR_BACKEND=null             # null | keyword | ollama
OLLAMA_HOST=https://ollama.com
OLLAMA_MODEL=gpt-oss:120b-cloud
OLLAMA_API_KEY=                    # OBLIGATOIRE pour Ollama Cloud (clé API)
# LLM_AGENT_MODEL=                 # vide ⇒ OLLAMA_MODEL
# LLM_EXTRACTOR_MODEL=

# --- Latence (LIVE-7.4) — leviers, défauts sûrs -----------------------------
SPECULATIVE_TRIGGER=false          # déclenchement spéculatif sur partiel stable (VAD)
BARGE_IN=true                      # interruption de l'agent à la reprise de parole
BACKCHANNEL=false                  # accusé immédiat (« d'accord… »)
# BACKCHANNEL_TEXT=D'accord…
AGENT_MAX_TOKENS=120               # agent concis
TTS_SENTENCE_CHUNKING=true         # synthèse par phrase (1er son plus tôt)
PROMPT_CACHE=true

# --- Divers -----------------------------------------------------------------
DEFAULT_LANGUAGE=fr
# CORS_ORIGINS=["https://app.client.example"]
SESSION_TOKEN_TTL_SECONDS=60
RESULT_RETENTION_SECONDS=600
MAX_USER_TURNS=12
