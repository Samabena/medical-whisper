# Reverse proxy prod (TLS automatique). Remplacer le nom d'hôte par le vôtre.
{$DOMAIN:localhost} {
	encode gzip

	# En-têtes de sécurité.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	# API REST + WebSocket live + ops → backend (Caddy gère l'upgrade WebSocket).
	@api path /v1/* /admin/api/* /health /metrics
	reverse_proxy @api backend:8000

	# Tout le reste → frontend (portail Admin).
	reverse_proxy frontend:80
}
