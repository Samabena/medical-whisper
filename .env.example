# Voice-to-Form Live — variables d'environnement (copier en .env, ne jamais committer).
# Architecture « sandwich » CPU : STT (faster-whisper) → agent + extracteur (Ollama) → TTS (Piper).
# Aucun GPU requis. Les secrets n'ont PAS de défaut sûr : renseignez-les avant tout démarrage.

# --- Déploiement ------------------------------------------------------------
# Nom d'hôte public (profil prod) : Caddy obtient un certificat TLS automatiquement.
DOMAIN=localhost

# --- Base de données / cache ------------------------------------------------
POSTGRES_USER=vtf
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=voicetoform
DATABASE_URL=postgresql+asyncpg://vtf:change-me-in-prod@db:5432/voicetoform
REDIS_URL=redis://redis:6379/0

# --- Sécurité (OBLIGATOIRES) ------------------------------------------------
# JWT_SECRET : au moins 32 caractères aléatoires (ex. `openssl rand -hex 32`).
JWT_SECRET=change-me-generate-a-long-random-secret-min-32-chars
ADMIN_EMAIL=admin@local
# Mot de passe admin : ADMIN_PASSWORD (clair, dev) OU ADMIN_PASSWORD_HASH (argon2, prod).
ADMIN_PASSWORD=change-me-strong-password
ADMIN_PASSWORD_HASH=
ADMIN_ACCESS_TTL_MINUTES=30
ADMIN_REFRESH_TTL_DAYS=7
RATE_LIMIT_PER_MINUTE=120

# --- Agent vocal ------------------------------------------------------------
# stub (dev, hors-ligne) | sandwich (prod : STT + agent + TTS) | llm (texte seul)
SPEECH_AGENT=stub

# --- STT (profil voice/prod) ------------------------------------------------
# stub (dev) | whisperlive (serveur WhisperLive en ligne de l'équipe)
STT_BACKEND=stub
WHISPERLIVE_URL=ws://srv-team-ia:9300
WHISPER_MODEL=small                 # large-v3 si CPU/GPU costaud
# STT_LANGUAGE=                      # vide ⇒ langue du compte/formulaire

# --- TTS (profil voice/prod) ------------------------------------------------
# stub (dev) | piper_http (serveur ./piper-server, recommandé Docker) | piper (binaire local)
TTS_BACKEND=stub
PIPER_URL=http://piper:5000
PIPER_VOICE=/voices/fr_FR-siwis-medium.onnx    # voix montée dans le conteneur piper
# TTS_VOICE_PATH=                   # (backend `piper` bare-metal) chemin .onnx local

# --- Agent conversationnel & extraction LLM (Ollama Cloud) ------------------
# agent : scripted (dev) | ollama (streaming)   ·   extraction : null (dev) | keyword | ollama
AGENT_BACKEND=scripted
EXTRACTOR_BACKEND=null
OLLAMA_HOST=https://ollama.com
OLLAMA_MODEL=gpt-oss:120b-cloud
OLLAMA_API_KEY=                     # OBLIGATOIRE pour Ollama Cloud (clé API)
# LLM_AGENT_MODEL=                  # modèle agent distinct (vide ⇒ OLLAMA_MODEL)
# LLM_EXTRACTOR_MODEL=              # modèle extracteur distinct (vide ⇒ OLLAMA_MODEL)

# --- Latence du pipeline live (leviers, défauts sûrs) -----------------------
SPECULATIVE_TRIGGER=false           # déclenchement spéculatif sur partiel stable (VAD)
BARGE_IN=true                       # interruption de l'agent à la reprise de parole
BACKCHANNEL=false                   # accusé immédiat (« d'accord… »)
AGENT_MAX_TOKENS=1024
TTS_SENTENCE_CHUNKING=true          # synthèse par phrase (1er son plus tôt)
PROMPT_CACHE=true

# --- Divers -----------------------------------------------------------------
DEFAULT_LANGUAGE=fr
CORS_ORIGINS=[]                     # liste JSON d'origines autorisées (vide = désactivé)
SESSION_TOKEN_TTL_SECONDS=60
RESULT_RETENTION_SECONDS=600        # rétention courte du formulaire final (donnée de santé)
MAX_USER_TURNS=12                   # garde-fou anti-boucle

# --- Frontend ---------------------------------------------------------------
VITE_API_BASE=/
